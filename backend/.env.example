# Server
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# Required: Supabase Postgres connection string
# Dashboard → Project Settings → Database → Connection string (URI)
# Prefer "Transaction" pooler (port 6543) for serverless/free tiers
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Required: random long secret for JWT
JWT_SECRET=change-me-to-a-long-random-string

# Frontend origin(s), comma-separated for production
# Example: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000
